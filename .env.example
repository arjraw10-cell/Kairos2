OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Conservative context budget used for token display and auto-compaction.
# Set this to the actual prompt limit accepted by your gateway/model.
# KAIROS_CONTEXT_WINDOW=262000
# Optional model-facing tool result cap (characters)
# KAIROS_MAX_TOOL_RESULT_CHARS=20000

# Gateway settings
KAIROS_GATEWAY_HOST=127.0.0.1
KAIROS_GATEWAY_PORT=8765
# Optional fallback workspace. Clients may provide any absolute path instead.
KAIROS_DEFAULT_WORKSPACE=
# Defaults to ~/.kairos when empty.
KAIROS_DATA_DIR=
KAIROS_MAX_CONCURRENT_RUNS=8
KAIROS_RUNTIME_IDLE_SECONDS=1800
# Optional bearer token. Required automatically if configured.
KAIROS_AUTH_TOKEN=
# Optional legacy chats.json path for one-time import into SQLite.
KAIROS_LEGACY_CHAT_FILE=
